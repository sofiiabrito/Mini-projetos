programa {
  funcao inicio() {
    
    real num , num2

    escreva("Digite Dois Números: ")
     leia(num)
     leia(num2)

     escreva(" Soma:" , num + num2)
     escreva(" Subtração:" , num - num2)
     escreva(" Multiplicação:" , num * num2)
     escreva(" Divisão:" , num / num2)

     
     

  }
}
