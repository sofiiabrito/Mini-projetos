programa {
  funcao inicio() {

    real nota1, nota2 , nota3, peso1, peso2, peso3 

    escreva("\nNota e peso 1: ", nota1 , peso1)
    leia( nota1, peso1)
    escreva("\nNota e peso 2: ", nota2 , peso2)
    leia( nota2, peso2)
    escreva("\nNota e peso 3: ", nota3 , peso3)
    leia(nota3, peso3)
    escreva((nota1 * peso1)+(nota2 * peso2)+(nota3 * peso3)/(peso1+peso2+peso3))

    }
}
